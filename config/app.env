# Application configuration

# Directory that contains your photos to scan
PHOTO_ROOT="/mnt/d/projects/newRDMD5IA/foto"

# SQLite database path (relative to project root or absolute)
DB_PATH="db/gallery.db"

# Log file (relative to project root or absolute)
LOG_FILE="logs/app.log"

# Ollama HTTP endpoint and model
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="gemma4:e4b"
LANGUAGE="italiano"

# Thumbnail and cache directories (relative to project root or absolute)
THUMB_DIR="data/thumbs"
CACHE_DIR="data/cache"

# API server host and port
HOST="127.0.0.1"
PORT="8080"

# Supported IMAGE extensions (comma-separated, lowercase, no spaces)
SUPPORTED_IMAGE_EXT=jpg,jpeg,png,gif,webp,tiff,bmp,heic,heif

# Supported VIDEO extensions (comma-separated, lowercase, no spaces)
SUPPORTED_VIDEO_EXT=mp4,mov,m4v,avi,webm,mkv,mts,m2ts

# (Deprecated alias kept for backwards-compat - use SUPPORTED_IMAGE_EXT instead)
SUPPORTED_EXT="jpg,jpeg,png,gif,webp"

# Numero di worker IA che elaborano le foto in parallelo
# Aumenta fino al numero di core disponibili (es. 4, 8).
# Tieni presente che Ollama gestisce una richiesta alla volta di default;
# aumentare AI_WORKERS ha senso se usi un backend multi-istanza o llama.cpp.
AI_WORKERS=8
DESC_RETRIES=3
DESC_SLEEP=1.5

# --- Pipeline video ---------------------------------------------------------
# Numero di frame da estrarre dal video per la descrizione AI
VIDEO_FRAMES=8

# Attiva (1) o disattiva (0) il frame_cleaner sui frame estratti dal video
FRAME_CLEANER_ENABLED=1
