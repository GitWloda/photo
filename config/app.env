# Application configuration

# Directory that contains your photos to scan
PHOTO_ROOT="/home/wloda/Downloads/foto"

# SQLite database path (relative to project root or absolute)
DB_PATH="db/gallery.db"

# Log file (relative to project root or absolute)
LOG_FILE="logs/app.log"

# Ollama HTTP endpoint and model
OLLAMA_URL="http://localhost:11434"
#OLLAMA_MODEL="gemma4:26b"
#OLLAMA_MODEL="qwen3.6:35b"
OLLAMA_MODEL="gemma4:e4b"
#OLLAMA_MODEL="llava:7b"
LANGUAGE="italiano"

# Thumbnail and cache directories (relative to project root or absolute)
THUMB_DIR="data/thumbs"
CACHE_DIR="data/cache"

# API server host and port
HOST="127.0.0.1"
PORT="8080"

# Supported image extensions (comma-separated, lowercase)
SUPPORTED_EXT="jpg,jpeg,png,gif,webp"

# Numero di worker IA che elaborano le foto in parallelo
# Aumenta fino al numero di core disponibili (es. 4, 8).
# Tieni presente che Ollama gestisce una richiesta alla volta di default;
# aumentare AI_WORKERS ha senso se usi un backend multi-istanza o llama.cpp.
AI_WORKERS=8
DESC_RETRIES=3
DESC_SLEEP=1.5


HOST=0.0.0.0
PORT=8080